{
   "action": {
      "default_title": "ScreenSmooth"
   },
   "background": {
      "service_worker": "src/background.js"
   },
   "content_scripts": [ {
      "js": [ "src/content.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_start"
   } ],
   "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://*.supabase.co https://*.dodopayments.com;"
   },
   "description": "ScreenSmooth creates beautiful screen recordings with automatic zooms, pans, and smooth cursor by AI that keep the viewer engaged.",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "assets/icons/icon48.png",
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "ScreenSmooth - Screen Recorder with AI Auto Zoom",
   "permissions": [ "activeTab", "storage", "scripting" ],
   "version": "0.4.0",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "src/record/record.html", "src/record/record.css", "src/record/record.js", "src/record/record-init.js", "src/record/license-gate.js", "src/popup/popup.html", "src/popup/popup.css", "src/popup/popup.js", "src/license/license.html", "src/license/license.js", "src/landingpage.js", "src/lemonsqueezy-checkout.js", "src/styles.css", "assets/ffmpeg/ffmpeg-core.js", "assets/ffmpeg/ffmpeg-core.wasm", "assets/ffmpeg/ffmpeg-core.worker.js", "assets/ffmpeg/ffmpeg-core-st.js", "assets/ffmpeg/ffmpeg-core-st.wasm", "assets/ffmpeg/ffmpeg.min.js", "assets/ffmpeg/util.min.js", "assets/ffmpeg/814.ffmpeg.js", "assets/bg/*.png", "src/lemon.js" ]
   } ]
}
